---
debug:
  ci: {{ dig "ci" "debug" false .Installer.Settings }}

################################################################################
# HELMET FOUNDATION
################################################################################
helmet_foundation:
  projects:
{{- range .Installer.Products }}
  {{- $active := true }}
  {{- if and (kindIs "bool" .Enabled) (eq .Enabled false) }}
    {{- $active = false }}
  {{- end }}
  {{- if and $active .Namespace }}
      - {{ .Namespace }}
  {{- end }}
{{- end }}

################################################################################
# HELMET INFRASTRUCTURE
################################################################################
helmet_infrastructure: {}

################################################################################
# HELMET INTEGRATIONS
################################################################################
helmet_integrations: {}

################################################################################
# HELMET NETWORKING
################################################################################
helmet_networking: {}

################################################################################
# HELMET OPERATORS
################################################################################
helmet_storage: {}

################################################################################
# HELMET STORAGE
################################################################################
helmet_storage: {}

################################################################################
# PRODUCT A
################################################################################
product_a: {}

################################################################################
# PRODUCT B
################################################################################
product_b: {}

################################################################################
# PRODUCT C
################################################################################
product_c: {}

